# FleetGuard Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://fleetguard:fleetguard@localhost:5432/fleetguard

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Device
DEVICE_OFFLINE_THRESHOLD_SECONDS=30
DEVICE_HEARTBEAT_INTERVAL_SECONDS=10

# Approval
APPROVAL_TIMEOUT_SECONDS=120

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
APP_NAME=FleetGuard Control Center
DEBUG=true
LOG_LEVEL=INFO
