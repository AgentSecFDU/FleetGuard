# FleetGuard — Local Development (SQLite, no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///fleetguard.db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=fleetguard-local-dev-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DEVICE_OFFLINE_THRESHOLD_SECONDS=300
APPROVAL_TIMEOUT_SECONDS=120
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_NAME=FleetGuard Control Center
DEBUG=true
LOG_LEVEL=INFO
